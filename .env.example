# Supabase (client — prefixo VITE_ obrigatório)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase (server — Cloudflare Workers / Lovable secrets)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IA e mídia (server-only)
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Export FFmpeg (microserviço Render/Railway)
FFMPEG_SERVICE_URL=https://your-ffmpeg-service.onrender.com
FFMPEG_SERVICE_SECRET=generate-a-long-random-secret

# Admin plataforma (server-only) — e-mails separados por vírgula OU flag no Supabase
PLATFORM_ADMIN_EMAILS=you@example.com
